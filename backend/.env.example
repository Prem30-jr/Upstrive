# ===========================================
# SERVER CONFIG
# ===========================================
PORT=5000
NODE_ENV=production

# ===========================================
# MONGODB ATLAS
# Get free cluster at: https://www.mongodb.com/atlas
# ===========================================
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.xxxxx.mongodb.net/upstrive

# ===========================================
# ADMIN API KEY (for Retool authentication)
# Generate a secure random key at: https://randomkeygen.com
# ===========================================
ADMIN_API_KEY=your-secure-random-key-here

# ===========================================
# EMAIL CONFIGURATION (Gmail SMTP)
# Use App Password from: https://myaccount.google.com/apppasswords
# ===========================================
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password

# ===========================================
# RAZORPAY (for payment processing)
# Get keys from: https://dashboard.razorpay.com/app/keys
# ===========================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# ===========================================
# CLOUDINARY (for file uploads)
# Get from: https://cloudinary.com/console
# ===========================================
CLOUDINARY_CLOUD_NAME=xxxxxxxxxxxxxx
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxx
